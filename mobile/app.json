{
  "expo": {
    "name": "Enlightenment",
    "slug": "enlightenment",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.enlightenment.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "package": "com.enlightenment.app"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png",
      "port": 8090
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "scheme": "enlightenment",
    "extra": {
      "eas": {
        "projectId": "your-project-id"
      }
    },
    "sdkVersion": "54.0.0"
  }
}
